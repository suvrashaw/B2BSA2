{
  "name": "b2bsa-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:styles": "stylelint \"src/**/*.css\"",
    "partytown:copy": "partytown copylib public/~partytown",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "typecheck": "tsc --noEmit --incremental false",
    "check": "npm run format:check && npm run lint && npm run lint:styles && npm run typecheck && npm run build",
    "analyze": "ANALYZE=true npm run build",
    "postbuild": "next-sitemap",
    "prepare": "husky",
    "knip": "knip",
    "depcheck": "depcheck"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.css": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@builder.io/partytown": "^0.10.3",
    "@gsap/react": "^2.1.2",
    "@radix-ui/react-slot": "^1.2.4",
    "@studio-freight/lenis": "^1.0.42",
    "@vercel/og": "^0.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "gsap": "^3.15.0",
    "lucide-react": "^1.12.0",
    "next": "16.2.4",
    "next-intl": "^4.11.0",
    "next-sitemap": "^4.2.3",
    "next-themes": "^0.4.6",
    "next-video": "^2.7.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-globe.gl": "^2.37.1",
    "react-icons": "^5.6.0",
    "react-scan": "^0.5.6",
    "react-use-measure": "^2.1.7",
    "schema-dts": "^2.0.0",
    "swiper": "^12.1.3",
    "tailwind-merge": "^3.5.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@next/bundle-analyzer": "^16.2.5",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "depcheck": "^1.4.7",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-no-secrets": "^2.3.3",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-tailwindcss": "^3.18.3",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "knip": "^6.12.0",
    "lint-staged": "^17.0.2",
    "prettier": "^3.8.3",
    "stylelint": "^17.11.0",
    "stylelint-config-clean-order": "^8.0.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
