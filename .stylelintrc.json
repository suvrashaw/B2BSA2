{
  "extends": ["stylelint-config-standard", "stylelint-config-clean-order"],
  "rules": {
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "tailwind",
          "apply",
          "variants",
          "responsive",
          "screen",
          "theme",
          "utility",
          "layer"
        ]
      }
    ],
    "no-descending-specificity": null,
    "declaration-empty-line-before": null
  }
}
